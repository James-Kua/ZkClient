{
  "name": "zkclient",
  "version": "1.0.0",
  "description": "ZooKeeper Client with interactive node visualization",
  "author": "ZkClient",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "electron ."
  },
  "dependencies": {
    "electron-log": "^5.1.7",
    "node-zookeeper-client": "^1.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-zookeeper-client": "^1.1.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.zkclient.app",
    "productName": "ZkClient",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dir"
    }
  }
}
